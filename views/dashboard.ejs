<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WorkHub - Dashboard</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        .tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 30px;
            border-bottom: 2px solid #334155;
            padding-bottom: 10px;
        }
        .tab {
            padding: 12px 24px;
            background: #1e293b;
            border: none;
            color: #94a3b8;
            border-radius: 8px 8px 0 0;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.2s;
        }
        .tab.active {
            background: #3b82f6;
            color: white;
        }
        .tab-content {
            display: none;
        }
        .tab-content.active {
            display: block;
        }
        .video-card {
            cursor: pointer;
        }
        .modal {
            display: none;
            position: fixed;
            z-index: 9999;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.85);
        }
        .modal-content {
            background: #1e293b;
            margin: 5% auto;
            padding: 20px;
            width: 90%;
            max-width: 900px;
            border-radius: 12px;
        }
        .close {
            color: #aaa;
            float: right;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <div class="app-container">
        <!-- Navbar -->
        <nav class="top-nav">
            <div class="nav-left">
                <div class="logo">
                    <i class="fas fa-bolt"></i>
                    <span>WorkHub</span>
                </div>
            </div>
            <div class="nav-right">
                <span style="margin-right:15px; color:#94a3b8;">Hola, <%= user.username %></span>
                <a href="/admin" class="btn-secondary">Administrar</a>
                <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i></a>
            </div>
        </nav>

        <div class="main-content">
            <div class="dashboard-header">
                <h1><i class="fas fa-home"></i> Panel de Trabajo</h1>
                <p>Bienvenido, <%= user.username %>.</p>
            </div>

            <!-- Pestañas -->
            <div class="tabs">
                <button class="tab active" onclick="showTab('enlaces')">Enlaces</button>
                <button class="tab" onclick="showTab('videos')">Videos</button>
                <button class="tab" onclick="showTab('objetivos')">Objetivos</button>
                <button class="tab" onclick="showTab('ranking')">Ranking</button>
            </div>

            <!-- Pestaña ENLACES -->
            <div id="enlaces" class="tab-content active">
                <h2 style="margin-bottom:20px;"><i class="fas fa-link"></i> Enlaces</h2>
                <div class="cards-grid">
                    <% links.filter(l => l.type === 'enlace' || !l.type).forEach(link => { %>
                        <a href="<%= link.url %>" target="_blank" class="card">
                            <div class="card-icon">
                                <% if (link.icon) { %>
                                    <img src="<%= link.icon %>" alt="" style="width:32px;height:32px;object-fit:contain;">
                                <% } else { %>
                                    <i class="fas fa-link"></i>
                                <% } %>
                            </div>
                            <div class="card-content">
                                <h3><%= link.title %></h3>
                                <p><%= link.category_name || 'General' %></p>
                            </div>
                        </a>
                    <% }) %>
                </div>
            </div>

            <!-- Pestaña VIDEOS -->
            <div id="videos" class="tab-content">
                <h2 style="margin-bottom:20px;"><i class="fas fa-play-circle"></i> Videos</h2>
                <div class="cards-grid">
                    <% links.filter(l => l.type === 'video').forEach(video => { %>
                        <div class="card video-card" onclick="playVideo('<%= video.url %>', '<%= video.title %>')">
                            <div class="card-icon">
                                <i class="fas fa-play" style="font-size:28px; color:#ef4444;"></i>
                            </div>
                            <div class="card-content">
                                <h3><%= video.title %></h3>
                                <p>Video de YouTube</p>
                            </div>
                        </div>
                    <% }) %>
                </div>
                <% if (links.filter(l => l.type === 'video').length === 0) { %>
                    <p style="color:#94a3b8;">No hay videos todavía. Añádelos desde el panel de administración.</p>
                <% } %>
            </div>

            <!-- Pestaña OBJETIVOS -->
            <div id="objetivos" class="tab-content">
                <h2><i class="fas fa-bullseye"></i> Objetivos Semanales</h2>
                <p style="color:#94a3b8; margin-top:20px;">Esta sección está en desarrollo.</p>
            </div>

            <!-- Pestaña RANKING -->
            <div id="ranking" class="tab-content">
                <h2><i class="fas fa-trophy"></i> Ranking por Clientes</h2>
                <p style="color:#94a3b8; margin-top:20px;">Esta sección está en desarrollo.</p>
            </div>
        </div>
    </div>

    <!-- Modal para reproducir videos -->
    <div id="videoModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeVideo()">&times;</span>
            <h3 id="videoTitle" style="margin-bottom:15px; color:white;"></h3>
            <div id="videoPlayer" style="position:relative; padding-bottom:56.25%; height:0; overflow:hidden;">
                <!-- YouTube iframe se inserta aquí -->
            </div>
        </div>
    </div>

    <script>
        function showTab(tab) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.tab').forEach(el => el.classList.remove('active'));
            document.getElementById(tab).classList.add('active');
            event.currentTarget.classList.add('active');
        }

        // === Función mejorada: Soporta Videos normales + YouTube Shorts ===
        function playVideo(url, title) {
            const modal = document.getElementById('videoModal');
            const playerContainer = document.getElementById('videoPlayer');
            const titleEl = document.getElementById('videoTitle');

            titleEl.innerText = title;
            playerContainer.innerHTML = '';

            let videoId = '';

            // YouTube normal: https://www.youtube.com/watch?v=VIDEO_ID
            if (url.includes('youtube.com/watch?v=')) {
                videoId = url.split('v=')[1].split('&')[0];
            } 
            // YouTube Shorts: https://www.youtube.com/shorts/VIDEO_ID
            else if (url.includes('youtube.com/shorts/')) {
                videoId = url.split('shorts/')[1].split('?')[0];
            } 
            // youtu.be (normal o short)
            else if (url.includes('youtu.be/')) {
                videoId = url.split('youtu.be/')[1].split('?')[0];
            }

            if (videoId) {
                const iframe = document.createElement('iframe');
                iframe.width = '100%';
                iframe.height = '100%';
                iframe.style.position = 'absolute';
                iframe.style.top = '0';
                iframe.style.left = '0';
                iframe.src = `https://www.youtube.com/embed/${videoId}`;
                iframe.frameBorder = '0';
                iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
                iframe.allowFullscreen = true;

                playerContainer.appendChild(iframe);
                modal.style.display = 'block';
            } else {
                alert('URL de video no válida. Asegúrate de pegar un enlace correcto de YouTube o Shorts.');
            }
        }

        function closeVideo() {
            const modal = document.getElementById('videoModal');
            const playerContainer = document.getElementById('videoPlayer');
            playerContainer.innerHTML = '';
            modal.style.display = 'none';
        }

        // Cerrar modal al hacer clic fuera
        window.onclick = function(event) {
            const modal = document.getElementById('videoModal');
            if (event.target === modal) {
                closeVideo();
            }
        }
    </script>
</body>
</html>
