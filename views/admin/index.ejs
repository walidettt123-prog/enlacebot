<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - WorkHub</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
<div class="app-container">
    <nav class="top-nav">
        <div class="nav-left">
            <div class="logo"><i class="fas fa-bolt"></i> <span>WorkHub <small>Admin</small></span></div>
        </div>
        <div class="nav-right">
            <a href="/dashboard" class="btn-secondary">Ver Dashboard</a>
            <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i></a>
        </div>
    </nav>

    <div style="padding:30px; max-width:1400px; margin:0 auto;">
        <h1 style="margin-bottom:10px;">Panel de Administración</h1>

        <% if (success) { %><div style="background:#166534;color:#86efac;padding:12px 20px;border-radius:8px;margin-bottom:20px;"><%= success %></div><% } %>
        <% if (error) { %><div style="background:#991b1b;color:#fca5a5;padding:12px 20px;border-radius:8px;margin-bottom:20px;"><%= error %></div><% } %>

        <!-- Formulario para añadir enlace -->
        <div style="background:#1e293b; padding:25px; border-radius:12px; margin-bottom:30px; border:1px solid #334155;">
            <h2 style="margin-bottom:20px;"><i class="fas fa-plus-circle"></i> Añadir nuevo enlace</h2>
            
            <form action="/admin/add-link" method="POST" enctype="multipart/form-data">
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">
                    <div>
                        <label>Título</label>
                        <input type="text" name="title" required style="width:100%; padding:10px; background:#0f172a; border:1px solid #334155; color:white; border-radius:8px;">
                    </div>
                    <div>
                        <label>URL</label>
                        <input type="url" name="url" required style="width:100%; padding:10px; background:#0f172a; border:1px solid #334155; color:white; border-radius:8px;">
                    </div>
                </div>

                <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-top:15px;">
                    <div>
                        <label>Categoría</label>
                        <select name="category_id" required style="width:100%; padding:10px; background:#0f172a; border:1px solid #334155; color:white; border-radius:8px;">
                            <% categories.forEach(cat => { %>
                                <option value="<%= cat.id %>"><%= cat.name %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div>
                        <label>Icono (sube una imagen)</label>
                        <input type="file" name="icon" accept="image/*" style="width:100%; padding:8px; background:#0f172a; border:1px solid #334155; color:white; border-radius:8px;">
                    </div>
                </div>

                <button type="submit" style="margin-top:20px; background:#3b82f6; color:white; padding:12px 30px; border:none; border-radius:8px; font-weight:600;">
                    <i class="fas fa-plus"></i> Añadir Enlace
                </button>
            </form>
        </div>

        <!-- Tabla de enlaces -->
        <div style="background:#1e293b; padding:25px; border-radius:12px; border:1px solid #334155;">
            <h2 style="margin-bottom:20px;">Enlaces existentes (<%= links.length %>)</h2>
            
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="background:#0f172a;">
                        <th style="padding:12px; text-align:left;">Icono</th>
                        <th style="padding:12px; text-align:left;">Título</th>
                        <th style="padding:12px; text-align:left;">URL</th>
                        <th style="padding:12px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% links.forEach(link => { %>
                    <tr style="border-bottom:1px solid #334155;">
                        <td style="padding:12px;">
                            <% if (link.icon) { %>
                                <img src="<%= link.icon %>" width="32" height="32" style="border-radius:6px; object-fit:contain;">
                            <% } else { %>
                                <i class="fas fa-link" style="font-size:24px; color:#64748b;"></i>
                            <% } %>
                        </td>
                        <td style="padding:12px;"><strong><%= link.title %></strong></td>
                        <td style="padding:12px;"><a href="<%= link.url %>" target="_blank" style="color:#60a5fa;"><%= link.url %></a></td>
                        <td style="padding:12px;">
                            <form action="/admin/delete-link" method="POST" style="display:inline;" onsubmit="return confirm('¿Eliminar?')">
                                <input type="hidden" name="id" value="<%= link.id %>">
                                <button type="submit" style="background:#ef4444; color:white; border:none; padding:6px 12px; border-radius:6px;">Eliminar</button>
                            </form>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>
</body>
</html>
