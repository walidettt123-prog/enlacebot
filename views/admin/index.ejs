<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - WorkHub</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
<div style="padding:30px; max-width:1200px; margin:0 auto;">
    <h1>Panel de Administración</h1>
    
    <% if (success) { %><div style="background:#166534;color:white;padding:12px 20px;border-radius:8px;margin:15px 0;"><%= success %></div><% } %>
    <% if (error) { %><div style="background:#991b1b;color:white;padding:12px 20px;border-radius:8px;margin:15px 0;"><%= error %></div><% } %>

    <!-- Formulario simple para añadir enlace -->
    <div style="background:#1e293b;padding:25px;border-radius:12px;margin-bottom:30px;">
        <h2>Añadir nuevo enlace</h2>
        <form action="/admin/add-link" method="POST">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
                <div>
                    <label>Título</label>
                    <input type="text" name="title" required style="width:100%;padding:10px;background:#0f172a;border:1px solid #334155;color:white;border-radius:8px;">
                </div>
                <div>
                    <label>URL</label>
                    <input type="url" name="url" required style="width:100%;padding:10px;background:#0f172a;border:1px solid #334155;color:white;border-radius:8px;">
                </div>
            </div>
            
            <div style="margin-top:15px;">
                <label>Categoría</label>
                <select name="category_id" required style="width:100%;padding:10px;background:#0f172a;border:1px solid #334155;color:white;border-radius:8px;">
                    <% categories.forEach(cat => { %>
                        <option value="<%= cat.id %>"><%= cat.name %></option>
                    <% }) %>
                </select>
            </div>

            <button type="submit" style="margin-top:20px;background:#3b82f6;color:white;padding:12px 25px;border:none;border-radius:8px;font-weight:600;">
                Añadir Enlace
            </button>
        </form>
    </div>

    <!-- Lista de enlaces -->
    <div style="background:#1e293b;padding:25px;border-radius:12px;">
        <h2>Enlaces (<%= links.length %>)</h2>
        <table style="width:100%; border-collapse:collapse; margin-top:15px;">
            <thead>
                <tr style="background:#0f172a;">
                    <th style="padding:12px; text-align:left;">Título</th>
                    <th style="padding:12px; text-align:left;">URL</th>
                    <th style="padding:12px;">Categoría</th>
                    <th style="padding:12px;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                <% links.forEach(link => { %>
                <tr style="border-bottom:1px solid #334155;">
                    <td style="padding:12px;"><%= link.title %></td>
                    <td style="padding:12px;"><a href="<%= link.url %>" target="_blank" style="color:#60a5fa;"><%= link.url %></a></td>
                    <td style="padding:12px;"><%= link.category_name || '-' %></td>
                    <td style="padding:12px;">
                        <form action="/admin/delete-link" method="POST" style="display:inline;" onsubmit="return confirm('¿Eliminar?')">
                            <input type="hidden" name="id" value="<%= link.id %>">
                            <button type="submit" style="background:#ef4444;color:white;border:none;padding:6px 14px;border-radius:6px;">Eliminar</button>
                        </form>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
</body>
</html>
